{
  "version": 2,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/admin/?$",
      "dest": "/dist/index.html"
    },
    {
      "src": "^/admin/(.+)$",
      "dest": "/dist/$1"
    },
    {
      "src": "^/api/admin$",
      "dest": "/api/admin.js"
    },
    {
      "src": "^/$",
      "dest": "/api"
    },
    {
      "src": "^/(.+)$",
      "dest": "/api?path=$1"
    }
  ]
}
